# LinguAR Environment Configuration
# Copy to .env and adjust values

# Database
DB_URL=postgresql://linguar:CHANGE_ME@localhost:5432/linguar

# Security
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
CORS_ORIGINS=https://your-domain.com

# Models (production defaults are CrisperWhisper + HuBERT-large)
# For low-RAM dev machines, override:
#   WHISPER_MODEL=openai/whisper-tiny
#   LAZY_MODELS=true
WHISPER_MODEL=nyrahealth/CrisperWhisper
HUBERT_MODEL=facebook/hubert-large-ls960-ft
LAZY_MODELS=false

# Celery / Redis
REDIS_URL=redis://redis:6379/0

# Deployment
DEPLOYMENT_MODE=server
DEBUG=false
